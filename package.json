{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "prisma generate && vite build && esbuild server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --external:fsevents --external:vite --external:pg-native --external:@prisma/client --format=esm",
    "start": "NODE_ENV=production node dist/server.js",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/compression": "^1.8.1",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
