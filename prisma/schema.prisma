// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id          String    @id @default(cuid())
  name        String
  category    String
  description String
  logo        String
  location    String
  hours       String
  phone       String
  rating      Float     @default(0)
  image       String
  gallery     String[]  @default([])
  isFeatured  Boolean   @default(false)
  products    Product[]
  reviews     Review[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  userName  String
  rating    Int
  comment   String
  date      DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id])
  storeId   String
}

model Product {
  id           String   @id @default(cuid())
  name         String
  price        String
  category     String
  image        String
  description  String
  isNewArrival Boolean  @default(false)
  store        Store    @relation(fields: [storeId], references: [id])
  storeId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteConfig {
  id                 String   @id @default("default")
  heroTitle          String   @default("China Economic Mall")
  heroSubtitle       String   @default("Accra's Premier Trade Destination")
  heroDescription    String   @default("Hundreds of stores. Unbeatable prices. From cutting-edge electronics to high-street fashion — discover everything you need all under one roof.")
  heroImages         String[] @default([])
  heroVideo          String   @default("/Mall 1.mp4")
  promoTitle         String   @default("Mid-Year Mega Sale")
  promoSubtitle      String   @default("Promotion")
  promoDiscount      String   @default("40%")
  loyaltyTitle       String   @default("Join Our Gold Rewards Tier")
  loyaltyDescription String   @default("Earn points on every purchase and get early access to major mall events, seasonal sales, and exclusive trade discounts.")
  contactPhone       String   @default("020 275 1082")
  contactAddress     String   @default("Darkuman, Accra, Ghana")
  openingHours       String   @default("07:30 - 21:30 DAILY")
  updatedAt          DateTime @updatedAt
}
